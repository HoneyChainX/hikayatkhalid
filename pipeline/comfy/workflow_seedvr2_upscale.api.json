{
  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input.mp4", "force_rate": 0, "custom_width": 0, "custom_height": 0,
      "frame_load_cap": 0, "skip_first_frames": 0, "select_every_nth": 1
    },
    "_meta": { "title": "INPUT" }
  },
  "2": {
    "class_type": "SeedVR2LoadDiTModel",
    "inputs": { "model": "seedvr2_ema_3b_fp8_e4m3fn.safetensors", "device": "cuda:0" },
    "_meta": { "title": "DIT" }
  },
  "3": {
    "class_type": "SeedVR2LoadVAEModel",
    "inputs": { "model": "ema_vae_fp16.safetensors", "device": "cuda:0" },
    "_meta": { "title": "VAE" }
  },
  "4": {
    "class_type": "SeedVR2VideoUpscaler",
    "inputs": {
      "image": ["1", 0], "dit": ["2", 0], "vae": ["3", 0],
      "seed": 42, "resolution": 1080, "max_resolution": 0,
      "batch_size": 5, "uniform_batch_size": false, "color_correction": "lab"
    },
    "_meta": { "title": "UPSCALE" }
  },
  "5": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["4", 0], "frame_rate": 16, "loop_count": 0,
      "filename_prefix": "hikayat_up", "format": "video/h264-mp4",
      "pingpong": false, "save_output": true
    },
    "_meta": { "title": "SAVE" }
  }
}
