# Hikayat Khalid — environment template. Copy to .env (git-ignored) and fill in.
# Nothing here is committed; every script reads keys from the environment only.

# --- which episode ---
EPISODE=ep01

# --- voices (Stage 5) ---
ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_multilingual_v2

# --- consistent keyframes (Stage 2) — any ONE of these backends ---
HF_TOKEN=                       # huggingface.co/settings/tokens — Flux Kontext (free)
NVIDIA_API_KEY=                 # build.nvidia.com — NVIDIA NIM
GEMINI_API_KEY=                 # ai.google.dev — nano-banana (image gen needs billing on)

# --- animation (Stage 3) — pick ONE path ---
# Path A · cloud (no GPU):
FAL_KEY=                        # fal.ai
# FAL_MODEL=fal-ai/bytedance/seedance/v1/lite/image-to-video
# FAL_RES=720p
# Path B · GPU box (ComfyUI):
COMFY_URL=                      # e.g. https://<pod-id>-8188.proxy.runpod.net
# COMFY_WORKFLOW=pipeline/comfy/workflow_ltx2_i2v.api.json
# KEYFRAME_DIR=build/ep01/img

# --- persist to Supabase (optional, Stage 6b) ---
SUPABASE_URL=https://dvxmgtelcismjumgxwkw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=      # paste locally only — NEVER commit

# --- assembly knobs (optional) ---
# EP01_W=1280
# EP01_H=720
# CLIP_FPS=24
